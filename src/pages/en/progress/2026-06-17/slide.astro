---
// src/pages/en/progress/2026-06-17/slide.astro
// progress-mode: English slide version (horizontal pagination, 5 pages: title/done/doing/next/metrics)
// Migrated to Astro content collection (getEntry) — see src/content.config.ts
// P1 #2 fix (2026-06-27): 加 meta-page 块, 跟 paper slide 一致
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { articleLd } from "../../../../lib/json-ld";
import { getEntry } from "astro:content";

const entry = await getEntry("progress", "2026-06-17");
if (!entry) throw new Error("progress 2026-06-17 not found in collection");
const p = entry.data as {
  id: string;
  project_name: string;
  period: string;
  done: string[];
  doing: string[];
  next: [string, string, string][];
  metrics?: Record<string, string>;
};

const TOTAL_SLIDES = 5;
---
<BaseLayout
  title={`${p.project_name} | progress-slide`}
  description={`${p.period} — done/doing/next`}
  lang="en"
  productType="slide"
  jsonLd={articleLd(p, "en")}
>
  <section class="slide-page active" data-page="1">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">01 / {String(TOTAL_SLIDES).padStart(2, "0")}</span>
    </div>
    <div class="col-span-12 flex flex-col justify-center items-center text-center gap-6">
      <hr class="accent-bar" />
      <p class="text-caption text-gray-rule">{p.period}</p>
      <h1 class="text-headline font-sans font-bold leading-tight max-w-6xl">{p.project_name}</h1>
      <hr class="swiss-rule w-40" />
      <p class="kicker">Progress Log · work-in-progress report</p>
    </div>
    <aside class="slide-info-corner" aria-label="Progress metadata">
      <dl>
        <dt>Period</dt>
        <dd>{p.period}</dd>
        <dt>Mode</dt>
        <dd>progress-mode · smoke test</dd>
        <dt>Products</dt>
        <dd>slide + report (bilingual)</dd>
      </dl>
    </aside>
  </section>

  <section class="slide-page" data-page="2">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">02 / {String(TOTAL_SLIDES).padStart(2, "0")}</span>
    </div>
    <div class="col-span-12 grid grid-cols-12 gap-4 content-center">
      <div class="col-span-12">
        <p class="kicker mb-3">Q1 · What was completed</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans">Done (completed)</h2>
      </div>
      <ol class="col-span-10 col-start-2 space-y-2 text-body">
        {p.done.map((d) => <li class="border-l-4 border-lemon-green pl-4">{d}</li>)}
      </ol>
    </div>
  </section>

  <section class="slide-page" data-page="3">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">03 / {String(TOTAL_SLIDES).padStart(2, "0")}</span>
    </div>
    <div class="col-span-12 grid grid-cols-12 gap-4 content-center">
      <div class="col-span-12">
        <p class="kicker mb-3">Q2 · In-progress items</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans">Doing (in progress)</h2>
      </div>
      <ul class="col-span-10 col-start-2 space-y-3 text-body">
        {p.doing.map((d) => <li class="border-l-4 border-lemon-yellow pl-4">{d}</li>)}
      </ul>
    </div>
  </section>

  <section class="slide-page" data-page="4">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">04 / {String(TOTAL_SLIDES).padStart(2, "0")}</span>
    </div>
    <div class="col-span-12 grid grid-cols-12 gap-4 content-center">
      <div class="col-span-12">
        <p class="kicker mb-3">Q3 · Next steps</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans">Next (planned)</h2>
      </div>
      <table class="col-span-12 text-body">
        <thead>
          <tr class="border-b border-gray-rule">
            <th class="text-left py-2">Task</th>
            <th class="text-left py-2">Agent</th>
            <th class="text-left py-2">Deadline</th>
          </tr>
        </thead>
        <tbody>
          {p.next.map(([task, agent, deadline]) => (
            <tr class="border-b border-gray-rule">
              <td class="py-2 pr-4">{task}</td>
              <td class="py-2 pr-4">{agent}</td>
              <td class="py-2">{deadline}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="slide-page" data-page="5">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">05 / {String(TOTAL_SLIDES).padStart(2, "0")}</span>
    </div>
    <div class="col-span-12 grid grid-cols-12 gap-4 content-center">
      <div class="col-span-12">
        <p class="kicker mb-3">Q4 · Quantitative metrics</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans">Metrics (indicators)</h2>
      </div>
      <dl class="col-span-10 col-start-2 grid grid-cols-2 gap-4 text-body">
        {Object.entries(p.metrics ?? {}).map(([k, v]) => (
          <div class="border-l-4 border-ikb-blue pl-4">
            <dt class="text-caption text-gray-rule">{k}</dt>
            <dd class="font-semibold mt-1">{v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</BaseLayout>
