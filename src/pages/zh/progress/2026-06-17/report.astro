---
// src/pages/zh/progress/2026-06-17/report.astro
// progress-mode: 中文 report 版本 (单栏 longform, scrollable)
// 改用 Astro content collection (getEntry) — 见 src/content.config.ts
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("progress", "2026-06-17");
if (!entry) throw new Error("progress 2026-06-17 not found in collection");
const p = entry.data as {
  id: string;
  project_name: string;
  period: string;
  done: string[];
  doing: string[];
  next: [string, string, string][];
  metrics?: Record<string, string>;
};
---
<BaseLayout
  title={`${p.project_name} | progress-report`}
  description={`${p.period} — done/doing/next`}
  lang="zh"
  productType="longform"
>
  <article>
    <header>
      <p class="text-caption text-gray-rule">{p.period}</p>
      <h1>{p.project_name}</h1>
      <p class="text-graphite">progress-mode 烟雾测试 · 周报归档</p>
      <hr class="swiss-rule" />
    </header>

    <section>
      <h2>Done (已完成)</h2>
      <ol>
        {p.done.map((d) => <li>{d}</li>)}
      </ol>
    </section>

    <section>
      <h2>Doing (进行中)</h2>
      <ul>
        {p.doing.map((d) => <li>{d}</li>)}
      </ul>
    </section>

    <section>
      <h2>Next (计划中)</h2>
      <table>
        <thead>
          <tr>
            <th>任务</th>
            <th>负责人</th>
            <th>截止</th>
          </tr>
        </thead>
        <tbody>
          {p.next.map(([task, agent, deadline]) => (
            <tr>
              <td>{task}</td>
              <td>{agent}</td>
              <td>{deadline}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Metrics (指标)</h2>
      <dl>
        {Object.entries(p.metrics ?? {}).map(([k, v]) => (
          <div>
            <dt>{k}</dt>
            <dd>{v}</dd>
          </div>
        ))}
      </dl>
    </section>

    <footer>
      <hr class="swiss-rule" />
      <p class="text-caption text-gray-rule">本文为 progress-mode 烟雾测试产物 · {p.id}</p>
    </footer>
  </article>
</BaseLayout>
