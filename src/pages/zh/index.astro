---
// src/pages/zh/index.astro - 中文版导航页（zh 路由）
import BaseLayout from "../../layouts/BaseLayout.astro";
import { webSiteLd } from "../../lib/json-ld";
import { getCollection } from "astro:content";

const papers = (await getCollection("papers")) as Array<{ id: string; data: { title_zh?: string; title_en?: string; published_date?: string } }>;
const progressEntries = (await getCollection("progress")) as Array<{ id: string; data: { project_name: string; period: string } }>;
const lang = "zh";
const paperCount = papers.length;
const progressCount = progressEntries.length;
// 4 产物 = paper × 2 (slide/summary) + progress × 2 (slide/report)
const productCount = paperCount * 2 + progressCount * 2;
---
<BaseLayout
  title="content2html"
  description={`内容 (arxiv paper / 本地 progress) → HTML (slide + long-form). ${paperCount} papers, ${progressCount} progress logs, ${productCount} 产物.`}
  lang="zh"
  productType="longform"
  jsonLd={webSiteLd("zh")}
>
  <header>
    <h1>content2html</h1>
    <p class="swiss-rule"></p>
    <p class="text-caption text-graphite mt-2">
      {paperCount} papers · {progressCount} progress logs · {productCount} 产物 · 双语 (zh/en)
    </p>
  </header>
  <main>
    <section>
      <h2>4 产物</h2>
      <ul>
        <li><strong>paper-slide.html</strong> — 学术组会 paper-reading 演讲 (横向翻页)</li>
        <li><strong>paper-summary.html</strong> — 异步阅读 paper 摘要 (单栏 long-form)</li>
        <li><strong>progress-slide.html</strong> — 周报/工作进展演讲 (横向翻页)</li>
        <li><strong>progress-report.html</strong> — 周报 long-form 归档 (单栏 long-form)</li>
      </ul>
    </section>
    <section>
      <h2>已生成 Papers ({paperCount})</h2>
      {paperCount > 0 ? (
        <ul>
          {papers.map((p) => (
            <li>
              <a href={`/content2html/${lang}/paper/${p.id}/slide/`}>{p.data.title_zh ?? p.data.title_en}</a>
              {p.data.published_date && <span class="caption"> · {p.data.published_date}</span>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-graphite">暂无 paper 产物。</p>
      )}
    </section>
    <section>
      <h2>Progress Logs ({progressCount})</h2>
      {progressCount > 0 ? (
        <ul>
          {progressEntries.map((p) => (
            <li>
              <a href={`/content2html/${lang}/progress/${p.id}/slide/`}>{p.data.project_name}</a>
              <span class="caption"> · {p.data.period}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-graphite">暂无 progress 产物。</p>
      )}
    </section>
    <section>
      <h2>状态</h2>
      <p>SKILL.md (主入口 trigger <code>/content2html</code>) 已上线，MVP 完成 + 部署到 <code>/content2html/zh/paper/{papers[0]?.id ?? "2606.18246"}/slide/</code>。</p>
    </section>
  </main>
</BaseLayout>
