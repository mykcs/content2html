---
// src/pages/zh/paper/2603.12109/slide.astro
// paper-mode: 中文 slide (横向翻页) — 11 Q&A + 4 图穿插
// v2 美学升级: 字号 +25%, Swiss editorial 签名 (accent-bar + kicker + 顶 kicker bar)
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { extractPaperBullets } from "../../../../lib/paper-bullets";
import PaperSlideBullet from "../../../../components/PaperSlideBullet.astro";

const entry = await getEntry("papers", "2603.12109");
if (!entry) throw new Error("paper 2603.12109 not found in collection");
const paper = entry.data as {
  id: string;
  arxiv_id?: string;
  title_zh: string;
  title_en: string;
  title_full_en?: string;
  authors: string[];
  authors_with_affil_en?: { name: string; affil: string[] }[];
  affiliations_en?: string[];
  abstract_zh: string;
  abstract_en: string;
  sections_zh: { heading: string; body: string }[];
  sections_en: { heading: string; body: string }[];
  key_takeaways: string[];
  published_date?: string;
  code_url?: string;
  venue?: string;
  venue_rank?: string;
  venue_url?: string;
  category?: string;
  field_large_zh?: string;
  field_large_en?: string;
  field_medium_zh?: string;
  field_medium_en?: string;
  field_small_zh?: string;
  field_small_en?: string;
  technologies_zh?: string[];
  technologies_en?: string[];
};

const FIG = "/content2html/figures/2603.12109";
const TITLE_EN = paper.title_full_en ?? paper.title_en;
const AUTHORS_EN = paper.authors_with_affil_en ?? paper.authors.map((n) => ({ name: n, affil: [] as string[] }));
const AFFILS_EN: string[] = paper.affiliations_en ?? Array.from(new Set(AUTHORS_EN.flatMap((a) => a.affil)));
// 预计算每个作者的 sup affiliation 数字, 避免 JSX 内嵌 .map((_,idx)=>) 渲染失败
const AUTHOR_SUP: string[] = AUTHORS_EN.map((a) =>
  a.affil.map((x) => String(AFFILS_EN.indexOf(x) + 1)).join(",")
);

// 精简 PPT：把 body 里的 "1./2./3. 段标题" 提取为 bullet，丢掉长段落
// 满足 "Slide 文字量不要太多" 设计原则
function extractBullets(body: string): string[] {
  const out: string[] = [];
  // 1) 编号段："1. xxx[:：]..." 单行
  const numbered = body.match(/^\d+\.\s+[^\n]+/gm);
  if (numbered) out.push(...numbered.map((s) => s.trim()));
  // 2) 中文 "解决方案概述：xxx" 段
  const solZh = body.match(/^解决方案概述[：:]\s*[^\n]+/gm);
  if (solZh) out.push(...solZh.map((s) => s.trim()));
  return out;
}

// 精简 Q&A H2: 去掉 "Q1." / "Q4.1" 等前缀, kicker 已担任定位 (e.g. "Q1 · 试图解决什么问题")
// summary.astro 仍保留 Q-prefix (FAQ 风格需要); slide.astro 此处去掉避免与 kicker 重复
function cleanHeading(heading: string): string {
  return heading.replace(/^Q\d+(?:\.\d+)?\.\s*/, "");
}
---
<BaseLayout
  title={`${paper.title_zh} | paper-slide`}
  description={paper.abstract_zh}
  lang="zh"
  productType="slide"
>
  <!-- Slide 1: Title (完整英文 title + 英文作者 + 英文单位) -->
  <section class="slide-page active" data-page="1">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">01 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col justify-center items-center text-center gap-6">
      <hr class="accent-bar" />
      <h1 class="text-headline font-sans font-bold leading-tight max-w-6xl">{TITLE_EN}</h1>
      <hr class="swiss-rule w-40" />
      <p class="text-body leading-relaxed max-w-6xl">
        {AUTHORS_EN.map((a, i) => <><span class="author-name">{a.name}</span><sup class="text-caption text-ikb-blue">{a.affil.map((x) => String(AFFILS_EN.indexOf(x) + 1)).join(",")}</sup>{i < AUTHORS_EN.length - 1 ? " · " : ""}</>)}
      </p>
      <ol class="text-caption text-graphite leading-relaxed list-none max-w-6xl text-left mt-2">
        {AFFILS_EN.map((aff, idx) => <li><sup class="text-ikb-blue font-semibold">{idx + 1}</sup> {aff}</li>)}
      </ol>
    </div>

    <!-- Slide 1 右下角元信息块: arxiv / 发布日期 / 代码 / 大中领域 / 技术栈 -->
    <aside class="slide-info-corner" aria-label="Paper metadata">
      <dl>
        <dt>arXiv</dt>
        <dd><a href={`https://arxiv.org/abs/${paper.arxiv_id ?? paper.id}`} target="_blank" rel="noopener noreferrer">{paper.arxiv_id ?? paper.id}</a></dd>
        <dt>Published</dt>
        <dd>{paper.published_date ?? "暂无"}</dd>
        <dt>Code</dt>
        <dd>
          {paper.code_url
            ? <a href={paper.code_url} target="_blank" rel="noopener noreferrer">{paper.code_url.replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "")}</a>
            : <span>暂无</span>}
        </dd>
        <dt>Venue</dt>
        <dd>
          {paper.venue_url
            ? <a href={paper.venue_url} target="_blank" rel="noopener noreferrer">{paper.venue ?? "—"}</a>
            : <>{paper.venue ?? "—"}</>}
          {paper.venue_rank && <span class="venue-rank">({paper.venue_rank})</span>}
        </dd>
        <dt>Field</dt>
        <dd>{paper.field_large_zh ?? "—"} / {paper.field_medium_zh ?? "—"} / {paper.field_small_zh ?? "—"}</dd>
        <dt>Tech</dt>
        <dd>{(paper.technologies_zh ?? []).join(" · ") || "—"}</dd>
      </dl>
    </aside>
  </section>


  <!-- Slide 3: Fig 1 概念图 (Vanilla SeL + AReW 修复示意) — r-2x1 (2.01:1) -->
  <section class="slide-page" data-page="2">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">02 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Figure 1 · 论文核心图</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight mb-4 max-w-5xl">信息自锁 (SeL) 与 AReW 缓解</h2>
      </div>
      <p class="caption flex-shrink-0">上: vanilla outcome-based RL 陷入自锁 (Uninformative AS + Anti-aligned BT); 下: AReW 通过方向性批评恢复 AS-BT 对齐 (Informative AS + Aligned BT)</p>
      <figure class="frame-img r-2x1 fit-contain flex-1">
        <img src={`${FIG}/fig1_pipeline.png`} alt="Fig 1: SeL overview + AReW mitigation" />
      </figure>
    </div>
  </section>

  <!-- Slide 4: Q1 -->
  <section class="slide-page" data-page="3">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">03 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q1 · 试图解决什么问题</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[0].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[0].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 5: Q2 -->
  <section class="slide-page" data-page="4">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">04 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q2 · 相关研究</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[1].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[1].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 6: Q3 -->
  <section class="slide-page" data-page="5">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">05 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q3 · 如何解决</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[2].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractPaperBullets(paper.sections_zh[2].body).map((b, i) => (
          <PaperSlideBullet bullet={b} index={b.kind === "formula" ? i : undefined} />
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 7: Fig 4 训练动态 4 panels — r-16x10 (1.56:1) -->
  <section class="slide-page" data-page="6">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">06 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Figure 4 · 训练动态 4 tasks</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight mb-4">训练动态结果</h2>
      </div>
      <p class="caption flex-shrink-0">vanilla PPO (红) vs AReW-AS ONLY (绿) vs AReW-AS+BT (蓝) Reward vs Training Steps; AReW 持续提升, vanilla 停滞</p>
      <figure class="frame-img r-16x10 fit-contain flex-1">
        <img src={`${FIG}/fig4_full.png`} alt="Fig 4: training dynamics" />
      </figure>
    </div>
  </section>

  <!-- Slide 8: Q4 (1/2) -->
  <section class="slide-page" data-page="7">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">07 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q4.1 · 实验 (设置 + Table 1)</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[3].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[3].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 9: Fig 3 跨算法泛化 3 panels — h-30 -->
  <section class="slide-page" data-page="8">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">08 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Figure 3 · 跨 RL 算法泛化</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight mb-4">PPO / GRPO / GSPO 三算法一致提升</h2>
      </div>
      <p class="caption flex-shrink-0">(a) MediQ 干预: outcome-RL 削弱反馈敏感性, 提升 belief consistency; (b) PE-F 在 GRPO; (c) FloDial-Easy 在 GSPO</p>
      <figure class="frame-img h-30 fit-contain">
        <img src={`${FIG}/fig3_full.png`} alt="Fig 3: algorithm generalization" />
      </figure>
    </div>
  </section>

  <!-- Slide 10: Q4 (2/2) -->
  <section class="slide-page" data-page="9">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">09 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q4.2 · 实验 (动态 + 鲁棒性 + λ)</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[4].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[4].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 11: Fig 5 lambda + Fig 6 τ²-bench — 双图 h-30 -->
  <section class="slide-page" data-page="10">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">10 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Figures 5+6 · 鲁棒性 + 真实场景</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight mb-4">λ 重加权与跨场景泛化</h2>
      </div>
      <p class="caption flex-shrink-0">图 5 (左): τ²-bench 训练动态 (a) reward (b) tool error (c) response token (d) instruction turn · 图 6 (右): τ²-bench AReW 客服场景</p>
      <div class="flex-1 grid grid-cols-2 gap-6 items-center">
        <figure class="frame-img h-30 fit-contain">
          <img src={`${FIG}/fig5_taubench.png`} alt="Fig 5: τ²-bench training dynamics — (a) rewards (b) tool execution errors (c) consumed response tokens (d) instruction turns" />
        </figure>
        <figure class="frame-img h-30 fit-contain">
          <img src={`${FIG}/gh-tau2-AREW.png`} alt="Fig 6: τ²-bench AReW customer service" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Slide 12: Q5 -->
  <section class="slide-page" data-page="11">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">11 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q5 · 进一步探索</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[5].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[5].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 13: Q6 -->
  <section class="slide-page" data-page="12">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">12 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Q6 · 总结</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[6].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[6].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 14: 核心贡献 -->
  <section class="slide-page" data-page="13">    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">13 / 13</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">Key Takeaways · 核心贡献</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight">核心贡献</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-5xl">
        {paper.key_takeaways.map((t) => (
          <li class="takeaway-item">{t}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
