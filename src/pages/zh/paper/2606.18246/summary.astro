---
// src/pages/zh/paper/2606.18246/summary.astro
// paper-mode: 中文 summary 版本 (单栏 long-form)
// 改用 Astro content collection (getEntry) — 见 src/content.config.ts
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { scholarlyArticleLd } from "../../../../lib/json-ld";

const entry = await getEntry("papers", "2606.18246");
if (!entry) throw new Error("paper 2606.18246 not found in collection");
const paper = entry.data as {
  id: string;
  arxiv_id?: string;
  title_zh: string;
  title_en: string;
  authors: string[];
  abstract_zh: string;
  abstract_en: string;
  sections_zh: { heading: string; body: string }[];
  sections_en: { heading: string; body: string }[];
  key_takeaways: string[];
};
---
<BaseLayout
  title={`${paper.title_zh} | paper-summary`}
  description={paper.abstract_zh}
  lang="zh"
  productType="longform"
  jsonLd={scholarlyArticleLd(paper, "zh", entry.id)}
>
  <article>
    <header>
      <p class="text-caption text-gray-rule">arXiv: {paper.arxiv_id ?? paper.id}</p>
      <h1>{paper.title_zh}</h1>
      <p class="text-graphite">{paper.authors.join(" · ")}</p>
      <hr class="swiss-rule" />
    </header>

    <section>
      <h2>摘要</h2>
      <p>{paper.abstract_zh}</p>
    </section>

    <section>
      <h2>核心贡献</h2>
      <ul>
        {paper.key_takeaways.map((t) => (
          <li>{t}</li>
        ))}
      </ul>
    </section>

    {paper.sections_zh.map((s) => (
      <section>
        <h2>{s.heading}</h2>
        <p>{s.body}</p>
      </section>
    ))}

    <footer>
      <hr class="swiss-rule" />
      <p class="text-caption text-gray-rule">本文为 paper-mode 烟雾测试产物 · {paper.id}</p>
    </footer>
  </article>
</BaseLayout>
