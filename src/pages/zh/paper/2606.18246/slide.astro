---
// src/pages/zh/paper/2606.18246/slide.astro
// paper-mode: 中文 slide (横向翻页) — 6 Q&A (Title + 5 sections from paper)
// Template style: 跟 2603.12109 对齐 (Title + Info-Corner + Q&A 配 extractBullets)
// v3.2 美学升级: Swiss editorial 签名 (accent-bar + kicker + top-accent)
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { scholarlyArticleLd } from "../../../../lib/json-ld";

const entry = await getEntry("papers", "2606.18246");
if (!entry) throw new Error("paper 2606.18246 not found in collection");
const paper = entry.data as {
  id: string;
  arxiv_id?: string;
  title_zh: string;
  title_en: string;
  authors: string[];
  abstract_zh: string;
  abstract_en: string;
  sections_zh: { heading: string; body: string }[];
  sections_en: { heading: string; body: string }[];
  key_takeaways: string[];
};

// 精简 PPT: extract "1./2./3. xxx" bullet titles from body, drop long paragraphs
function extractBullets(body: string): string[] {
  const out: string[] = [];
  const numbered = body.match(/^\d+\.\s+[^\n]+/gm);
  if (numbered) out.push(...numbered.map((s) => s.trim()));
  return out;
}

// Strip "1." / "Q1." prefix from section heading (kicker already labels position)
function cleanHeading(heading: string): string {
  return heading.replace(/^\d+\.\s*/, "").replace(/^Q\d+(?:\.\d+)?\.\s*/, "");
}

// Q&A kicker labels — 每节一个角色
const KICKERS = [
  "Q1 · 试图解决什么问题",   // sections_zh[0]
  "Q2 · 方法",                // sections_zh[1]
  "Q3 · 实验",                // sections_zh[2]
  "Q4 · 分析",                // sections_zh[3]
  "Q5 · 总结",                // sections_zh[4]
];
---
<BaseLayout
  title={`${paper.title_zh} | paper-slide`}
  description={paper.abstract_zh}
  lang="zh"
  productType="slide"
  jsonLd={scholarlyArticleLd(paper, "zh")}
>
  <!-- Slide 1: Title + Info Corner -->
  <section class="slide-page active" data-page="1">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">01 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col justify-center items-center text-center gap-6">
      <hr class="accent-bar" />
      <h1 class="text-headline font-sans font-bold leading-tight max-w-6xl">{paper.title_zh}</h1>
      <hr class="swiss-rule w-40" />
      <p class="text-body leading-relaxed max-w-6xl">{paper.authors.join(" · ")}</p>
    </div>

    <!-- Slide 1 左下角元信息块: arXiv / 章节 / 关键贡献数 -->
    <aside class="slide-info-corner" aria-label="Paper metadata">
      <dl>
        <dt>arXiv</dt>
        <dd><a href={`https://arxiv.org/abs/${paper.arxiv_id ?? paper.id}`} target="_blank" rel="noopener noreferrer">{paper.arxiv_id ?? paper.id}</a></dd>
        <dt>章节</dt>
        <dd>{paper.sections_zh.length} 节 / 摘要 + 方法 + 实验 + 分析 + 总结</dd>
        <dt>关键贡献</dt>
        <dd>{paper.key_takeaways.length} 条</dd>
        <dt>主题</dt>
        <dd>非均匀宽度 Transformer (× 形 &gt;&lt;former)</dd>
        <dt>范围</dt>
        <dd>200M ~ 3B 参数 (稠密 + MoE)</dd>
      </dl>
    </aside>
  </section>

  <!-- Slide 2: 摘要 (Abstract) -->
  <section class="slide-page" data-page="2">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">02 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">摘要 · Abstract</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight mb-4">一句话总结</h2>
      </div>
      <p class="caption flex-shrink-0">× 形 (&gt;&lt;former) 架构: 保留首尾层宽度而压缩中间层, 形成参数瓶颈. 节省 22% FLOPs + 15% KV cache, 在 200M-3B 参数上 loss 优于参数匹配均匀 baseline.</p>
      <div class="flex-1 flex items-center">
        <p class="text-body leading-relaxed max-w-6xl">{paper.abstract_zh}</p>
      </div>
    </div>
  </section>

  <!-- Slide 3: Q1 引言 -->
  <section class="slide-page" data-page="3">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">03 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">{KICKERS[0]}</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[0].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[0].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 4: Q2 方法 -->
  <section class="slide-page" data-page="4">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">04 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">{KICKERS[1]}</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[1].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[1].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 5: Q3 实验 -->
  <section class="slide-page" data-page="5">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">05 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">{KICKERS[2]}</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[2].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[2].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Slide 6: Q4 分析 -->
  <section class="slide-page" data-page="6">
    <div class="slide-top-accent"></div>
    <div class="slide-meta-bar">
      <span class="meta-page">06 / 06</span>
    </div>

    <div class="col-span-12 flex flex-col gap-5 h-full">
      <div>
        <p class="kicker mb-3">{KICKERS[3]}</p>
        <hr class="accent-bar mb-6" />
        <h2 class="text-headline font-sans font-bold leading-tight max-w-5xl">{cleanHeading(paper.sections_zh[3].heading)}</h2>
      </div>
      <ul class="flex-1 flex flex-col gap-3 justify-center max-w-7xl">
        {extractBullets(paper.sections_zh[3].body).map((b) => (
          <li class="takeaway-item">{b}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>