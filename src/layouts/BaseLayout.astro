---
// BaseLayout.astro - content2html 主 layout
// 4 产物 (paper-slide / paper-summary / progress-slide / progress-report) 共用
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: "zh" | "en";
  productType?: "slide" | "longform";
}

const { title, description = "", lang = "zh", productType = "longform" } = Astro.props;

// === 中英文切换 URL (与主站 Masthead.astro:30-34 算法一致) ===
// 适配 content2html i18n: defaultLocale='zh' + prefixDefaultLocale=true
//   zh → 走 / (无前缀); en → 走 /en/ (有前缀)
// ⚠️ 关键: base='/content2html' 时 Astro 对 href="/..." 自动加 base prefix
//   必须用 import.meta.env.BASE_URL 显式拼, 避免 base prefix 重复
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ""); // 去掉末尾 /
const isCurrentlyEn = Astro.url.pathname.startsWith(`${baseUrl}/en`);
const strippedPath =
  Astro.url.pathname.replace(new RegExp(`^${baseUrl}/?(en|zh)?`), "") || "/";
const targetLang = isCurrentlyEn ? "zh" : "en";
const targetPrefix = targetLang === "en" ? "/en" : "/zh";
const switchUrl = `${baseUrl}${targetPrefix}${strippedPath === "/" ? "/" : strippedPath}`;
const switchTitle = targetLang === "en" ? "Switch to English" : "切换到中文";
---
<!doctype html>
<html lang={lang} class={productType === "slide" ? "slide-mode" : "longform-mode"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={productType === "slide" ? "slide-deck" : "longform"}>
    <!--
      语言切换: 跟主站 Masthead 行为一致 (圆形按钮 + 文字 + sticky 顶部),
      适配 swiss 风格 (Helvetica + 发丝线边框)
    -->
    <nav class="lang-toggle" aria-label="Language switcher">
      <a href={switchUrl} title={switchTitle} aria-label={switchTitle}>
        <span class={targetLang === "zh" ? "lang-active" : "lang-inactive"}>中</span>
        <span class="lang-sep">/</span>
        <span class={targetLang === "en" ? "lang-active" : "lang-inactive"}>EN</span>
      </a>
    </nav>
    <slot />
  </body>
</html>

<style>
  /* swiss 风格: 圆形 pill, 0.5pt 黑色边框, 灰白底, 浮在右上角 */
  .lang-toggle {
    position: fixed;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 50;
    background: rgba(250, 250, 250, 0.95);
    border: 0.5px solid var(--color-black);
    border-radius: 9999px;
    padding: 0.25rem 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    line-height: 1.25rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .lang-toggle a {
    text-decoration: none;
    color: var(--color-black);
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }
  .lang-toggle .lang-active {
    font-weight: 700;
    color: var(--color-ikb-blue);
  }
  .lang-toggle .lang-inactive {
    color: var(--color-graphite);
    opacity: 0.55;
  }
  .lang-toggle .lang-sep {
    color: var(--color-gray-rule);
    margin: 0 0.15rem;
    user-select: none;
  }
  .lang-toggle a:hover .lang-inactive {
    opacity: 1;
  }
  .lang-toggle a:hover .lang-active {
    color: var(--color-ikb-blue-dark);
  }

  /* Slide 模式: 不遮顶, 留 padding 兼容 16:9 标题 */
  .slide-deck .lang-toggle {
    /* slide-deck 是 position: relative, fixed 仍相对 viewport */
  }

  @media print {
    .lang-toggle { display: none; }
  }
</style>
