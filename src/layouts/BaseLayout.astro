---
// BaseLayout.astro - content2html 主 layout
// 4 产物 (paper-slide / paper-summary / progress-slide / progress-report) 共用
//
// 语言切换按钮: 跟主站 Masthead.astro:77-83 完全同款 (圆形深灰按钮 + translate.svg 图标),
// 路径算法沿用主站 Masthead.astro:30-34 (剥离当前 locale 前缀, 拼接目标 locale 前缀)
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: "zh" | "en";
  productType?: "slide" | "longform";
}

const { title, description = "", lang = "zh", productType = "longform" } = Astro.props;

// === 中英文切换 URL (与主站 Masthead.astro:30-34 算法一致) ===
// 适配 content2html i18n: defaultLocale='zh' + prefixDefaultLocale=true
//   zh → 走 / (无前缀); en → 走 /en/ (有前缀)
// ⚠️ 关键: base='/content2html' 时 Astro 对 href="/..." 自动加 base prefix
//   必须用 import.meta.env.BASE_URL 显式拼, 避免 base prefix 重复
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ""); // 去掉末尾 /
const isCurrentlyEn = Astro.url.pathname.startsWith(`${baseUrl}/en`);
const strippedPath =
  Astro.url.pathname.replace(new RegExp(`^${baseUrl}/?(en|zh)?`), "") || "/";
const targetLang = isCurrentlyEn ? "zh" : "en";
const targetPrefix = targetLang === "en" ? "/en" : "/zh";
const switchUrl = `${baseUrl}${targetPrefix}${strippedPath === "/" ? "/" : strippedPath}`;
const switchTitle = targetLang === "en" ? "Switch to English" : "切换到中文";
const iconUrl = `${baseUrl}/icons/translate.svg`;
---
<!doctype html>
<html lang={lang} class={productType === "slide" ? "slide-mode" : "longform-mode"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Canonical + hreflang alternates (P1 #3 + #4)
        算法: 剥除当前 locale 前缀 (zh / en), 用 BASE_URL + Astro.site 拼绝对 URL
        适配 prefixDefaultLocale: true (zh 走 /, en 走 /en/)
    */}
    {(() => {
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const siteUrl = (Astro.site ?? new URL("https://mykcs.github.io")).toString().replace(/\/$/, "");
      const pathWithoutLocale = Astro.url.pathname
        .replace(new RegExp(`^${baseUrl}/?(en|zh)?`), "")
        .replace(/^\//, "") || "/";
      const enHref = `${siteUrl}${baseUrl}/en${pathWithoutLocale === "/" ? "/" : "/" + pathWithoutLocale}`;
      const zhHref = `${siteUrl}${baseUrl}${pathWithoutLocale === "/" ? "/" : "/" + pathWithoutLocale}`;
      const canonicalHref = `${siteUrl}${Astro.url.pathname}`;
      return (
        <>
          <link rel="canonical" href={canonicalHref} />
          <link rel="alternate" hreflang="zh" href={zhHref} />
          <link rel="alternate" hreflang="en" href={enHref} />
          <link rel="alternate" hreflang="x-default" href={zhHref} />

          {/* Open Graph + Twitter */}
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={canonicalHref} />
          <meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />
          <meta property="og:type" content="website" />
          <meta name="twitter:card" content="summary" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
        </>
      );
    })()}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={productType === "slide" ? "slide-deck" : "longform"}>
    <!--
      右上角浮动工具栏 (跟主站 CVActionBar.astro:22 模式一致: flex 容器 + 多按钮 gap-2).
      - lang-toggle: 跟主站 Masthead.astro:79-81 同款 (深灰圆形 + translate.svg), 中英文切换
      - dev-btn (slide-only): Lucide play-circle 图标 + "开发" 标签 + shields.io badge
        · 图标: 语义化"运行", 替代通用 octocat
        · badge: GH Actions 官方 API (deploy.yml/badge.svg), 自动随 build 状态变色 (绿/红/灰)
        · 整块 click → /actions; badge 区域显示当前 build 状态
    -->
    <div class="fixed top-4 right-4 z-50 flex items-center gap-2">
      {productType === "slide" && (
        <a
          href="https://github.com/mykcs/content2html/actions"
          target="_blank"
          rel="noopener noreferrer"
          class="dev-btn flex items-center gap-2 px-2.5 py-1.5 bg-gray-700 hover:bg-gray-600 text-white rounded-md transition-colors shadow-md no-underline"
          title="开发 (GitHub Actions) — 点击查看 build 状态"
          aria-label="GitHub Actions build status"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polygon points="10 8 16 12 10 16 10 8"></polygon>
          </svg>
          <span class="text-[11px] font-semibold uppercase tracking-wider">开发</span>
          <span class="h-3.5 w-px bg-white/25" aria-hidden="true"></span>
          <img
            src="https://github.com/mykcs/content2html/actions/workflows/deploy.yml/badge.svg?branch=main&style=flat-square"
            alt="build status"
            class="h-3.5 -mr-1"
            loading="lazy"
            decoding="async"
          />
        </a>
      )}
      <a
        href={switchUrl}
        class="lang-toggle flex items-center bg-gray-700 hover:bg-gray-600 text-white rounded-full p-2 transition-colors shadow-md"
        title={switchTitle}
        aria-label={switchTitle}
      >
        <img
          src={iconUrl}
          alt=""
          class="h-4 w-auto"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
    <slot />
    {productType === "slide" && (
      <div class="slide-controls" role="toolbar" aria-label="Slide controls">
        <span class="slide-controls__label">Preview:</span>
        <span class="slide-controls__zoom" id="slide-zoom-level">Fit</span>
        <div class="slide-controls__group">
          <button data-zoom="0.5" title="Zoom 50%" aria-label="缩小">−</button>
          <button data-zoom="1" title="Zoom 100%" aria-label="放大">+</button>
        </div>
        <button data-zoom="fit" class="active" title="Fit to window (0)" aria-label="适应屏幕">Fit</button>
        <span class="slide-controls__divider"></span>
        <button data-zoom="print" class="slide-controls__print" title="Print / Save as PDF (P)" aria-label="打印 PDF">Print PDF</button>
      </div>
    )}
    {productType === "slide" && (
      <script>
        import "../scripts/slide-nav";
      </script>
    )}
  </body>
</html>

<style>
  /* slide-deck (16:9 全屏) 模式: 不在顶, 留 16px 间距 */
  .slide-deck .lang-toggle {
    /* fixed 默认相对 viewport, slide-deck 16:9 顶距 = 0 时按 frame 顶 */
  }
  @media print {
    .lang-toggle, .dev-btn { display: none; }
  }
</style>
